# Copy these into Vercel Project Settings -> Environment Variables
# (Do not commit a real .env file with actual secrets.)

GITHUB_TOKEN=your_personal_access_token_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_desired_repo_name
GITHUB_BRANCH=main

# Legacy single admin/service key. Example for local testing only:
API_KEY=Testplay

# Optional comma-separated scoped keys: name:key:role
# Roles currently supported by policy checks: admin, service, anon
API_KEYS=dashboard:replace_me_admin:admin,public:replace_me_anon:anon

# GitHub API optimization: REST row writes respond immediately, then coalesce
# multiple changes to the same table into one GitHub commit after this delay.
ENGINE_BUFFERED_WRITES=true
ENGINE_WRITE_FLUSH_MS=1000
ENGINE_SCHEMA_CACHE_MS=30000
