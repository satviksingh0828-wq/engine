{
  "version": 2,
  "installCommand": "npm install --omit=dev",
  "rewrites": [
    { "source": "/auth/v1/:path*", "destination": "/api/auth/v1/:path*" },
    { "source": "/rest/v1/:path*", "destination": "/api/rest/v1/:path*" },
    { "source": "/storage/v1/:path*", "destination": "/api/storage/v1/:path*" }
  ]
}
